generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// PLANES SAAS
// ──────────────────────────────────────────────
model Plan {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  billing_cycle String         // e.g. "monthly", "yearly"
  max_users     Int
  max_storage_mb Int
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}

// ──────────────────────────────────────────────
// TENANTS (EMPRESAS / CLIENTES)
// ──────────────────────────────────────────────
model Tenant {
  id            String          @id @default(uuid())
  name          String
  slug          String          @unique
  legal_name    String?
  tax_id        String?
  email         String?
  phone         String?
  logo          String?         @db.Text
  country       String?
  city          String?
  municipality  String?
  street        String?
  number        String?
  postal_code   String?
  whatsapp      String?
  status        String          // active, suspended, pending, cancelled
  plan_id       String
  plan          Plan            @relation(fields: [plan_id], references: [id])
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  created_by    String?
  updated_by    String?
  users                  User[]
  roles                  Role[]
  subscriptions          Subscription[]
  settings               TenantSetting[]
  audit_logs             AuditLog[]
  payments               Payment[]
  taxes                  TaxSetting[]
  systems                CatalogSystem[]
  finishes               CatalogFinish[]
  catalog_items          CatalogItem[]
  engineering_templates  EngineeringTemplate[]
  clients                Client[]
  projects               Project[]
  quotes                 Quote[]
  suppliers              Supplier[]
  warehouses             Warehouse[]
  inventory_items        InventoryItem[]
  inventory_movements    InventoryMovement[]
  purchase_orders        PurchaseOrder[]

  @@index([status])
  @@index([plan_id])
  @@map("tenants")
}

// ──────────────────────────────────────────────
// USUARIOS
// ──────────────────────────────────────────────
model User {
  id                  String         @id @default(uuid())
  tenant_id           String?
  tenant              Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  email               String         @unique
  username            String?
  password_hash       String
  first_name          String?
  last_name           String?
  phone               String?
  status              String         // active, inactive, pending, locked
  last_login_at       DateTime?
  password_changed_at DateTime?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  created_by          String?
  updated_by          String?
  roles               UserRole[]
  refresh_tokens      RefreshToken[]
  audit_logs          AuditLog[]
  inventory_movements InventoryMovement[]

  @@index([tenant_id])
  @@index([email])
  @@index([status])
  @@map("users")
}

// ──────────────────────────────────────────────
// ROLES
// ──────────────────────────────────────────────
model Role {
  id            String           @id @default(uuid())
  tenant_id     String?          // null indica un rol global de la plataforma
  tenant        Tenant?          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name          String
  description   String?
  is_system_role Boolean         @default(false)
  is_active     Boolean          @default(true)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  permissions   RolePermission[]
  users         UserRole[]

  @@index([tenant_id])
  @@map("roles")
}

// ──────────────────────────────────────────────
// PERMISOS
// ──────────────────────────────────────────────
model Permission {
  id          String           @id @default(uuid())
  code        String           @unique // e.g. "users.create"
  name        String
  description String?
  module      String           // e.g. "users"
  action      String           // e.g. "create"
  is_active   Boolean          @default(true)
  roles       RolePermission[]

  @@map("permissions")
}

// ──────────────────────────────────────────────
// RELACIÓN ROLES - PERMISOS
// ──────────────────────────────────────────────
model RolePermission {
  id            String     @id @default(uuid())
  role_id       String
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  created_at    DateTime   @default(now())

  @@unique([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
  @@map("role_permissions")
}

// ──────────────────────────────────────────────
// RELACIÓN USUARIOS - ROLES
// ──────────────────────────────────────────────
model UserRole {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role_id    String
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

// ──────────────────────────────────────────────
// REFRESH TOKENS (SESIONES ACTIVAS)
// ──────────────────────────────────────────────
model RefreshToken {
  id            String    @id @default(uuid())
  user_id       String
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash    String
  expires_at    DateTime
  revoked_at    DateTime?
  created_at    DateTime  @default(now())
  created_by_ip String?
  user_agent    String?

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────
// SUSCRIPCIONES
// ──────────────────────────────────────────────
model Subscription {
  id            String    @id @default(uuid())
  tenant_id     String
  tenant        Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plan_id       String
  plan          Plan      @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  status        String    // trial, active, past_due, cancelled, expired
  start_date    DateTime
  end_date      DateTime
  trial_ends_at DateTime?
  cancelled_at  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([tenant_id])
  @@index([plan_id])
  @@map("subscriptions")
}

// ──────────────────────────────────────────────
// CONFIGURACIÓN DE TENANTS
// ──────────────────────────────────────────────
model TenantSetting {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  key        String
  value      String
  value_type String   // string, number, boolean, json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, key])
  @@index([tenant_id])
  @@map("tenant_settings")
}

// ──────────────────────────────────────────────
// LOGS DE AUDITORÍA
// ──────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  tenant_id   String?
  tenant      Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  action      String
  module      String
  entity_name String
  entity_id   String
  old_value   String?  @db.Text
  new_value   String?  @db.Text
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@index([tenant_id])
  @@index([user_id])
  @@index([created_at])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────
// ELEMENTOS DE MENÚ DINÁMICO
// ──────────────────────────────────────────────
model MenuItem {
  id                 String     @id @default(uuid())
  parent_id          String?
  parent             MenuItem?  @relation("MenuItemHierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children           MenuItem[] @relation("MenuItemHierarchy")
  code               String     @unique
  label              String
  route              String
  icon               String?
  required_permission String?
  order              Int        @default(0)
  is_active          Boolean    @default(true)

  @@map("menu_items")
}

// ──────────────────────────────────────────────
// PAGOS Y FACTURACIÓN
// ──────────────────────────────────────────────
model Payment {
  id             String   @id @default(uuid())
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("USD")
  status         String   // pending, completed, failed
  gateway        String   // paypal, stripe, mock
  transaction_id String?  @unique // ID de transacción/orden del procesador
  payer_email    String?
  payer_name     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("payments")
  @@index([tenant_id])
}

// ──────────────────────────────────────────────
// PARÁMETROS DE IMPUESTOS
// ──────────────────────────────────────────────
model TaxSetting {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name       String
  rate       Decimal  @db.Decimal(5, 2)
  is_active  Boolean  @default(true)
  is_default Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("tax_settings")
}

// ──────────────────────────────────────────────
// SISTEMAS Y LÍNEAS
// ──────────────────────────────────────────────
model CatalogSystem {
  id            String        @id @default(uuid())
  tenant_id     String?
  tenant        Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name          String
  description   String?
  is_active     Boolean       @default(true)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  catalog_items          CatalogItem[]
  engineering_templates  EngineeringTemplate[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("catalog_systems")
}

// ──────────────────────────────────────────────
// ACABADOS Y COLORES
// ──────────────────────────────────────────────
model CatalogFinish {
  id               String   @id @default(uuid())
  tenant_id        String?
  tenant           Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name             String
  code             String?
  price_multiplier Decimal  @default(1.00) @db.Decimal(5, 2)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  
  catalog_items    CatalogItem[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("catalog_finishes")
}

// ──────────────────────────────────────────────
// ARTÍCULOS MAESTROS DEL CATÁLOGO
// ──────────────────────────────────────────────
model CatalogItem {
  id               String         @id @default(uuid())
  tenant_id        String?
  tenant           Tenant?         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  code             String
  name             String
  description      String?
  type             String         // profile, glass, accessory, supply
  unit             String         // m, m2, u, kg, etc.
  cost             Decimal        @db.Decimal(10, 2)
  last_cost        Decimal?       @db.Decimal(10, 2)
  average_cost     Decimal?       @db.Decimal(10, 2)
  price_1          Decimal?       @db.Decimal(10, 2)
  price_2          Decimal?       @db.Decimal(10, 2)
  price_3          Decimal?       @db.Decimal(10, 2)
  price_4          Decimal?       @db.Decimal(10, 2)
  image            String?        @db.Text
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  // Jerarquía Padre/Hijo para Acabados
  base_item_id     String?
  base_item        CatalogItem?   @relation("ItemVariants", fields: [base_item_id], references: [id])
  variants         CatalogItem[]  @relation("ItemVariants")
  finish_id        String?
  finish           CatalogFinish? @relation(fields: [finish_id], references: [id])

  // Campos específicos de Perfiles
  weight_per_meter Decimal?       @db.Decimal(6, 3)
  standard_length  Decimal?       @db.Decimal(5, 2)
  system_id        String?
  system           CatalogSystem? @relation(fields: [system_id], references: [id], onDelete: SetNull)

  // Campos específicos de Vidrios
  thickness_mm     Decimal?       @db.Decimal(4, 1)
  glass_type       String?        // monolithic, tempered, laminated, double
  weight_per_m2    Decimal?       @db.Decimal(6, 3)

  // Relación inversa con Ingeniería
  engineering_components EngineeringComponent[]
  
  // Relación inversa con Cotizaciones
  quoted_products QuotedProduct[]

  // Relaciones inversas de Inventario y Compras
  inventory_items      InventoryItem[]
  purchase_order_items PurchaseOrderItem[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([type])
  @@map("catalog_items")
}

// ──────────────────────────────────────────────
// CONFIGURACIÓN GLOBAL DE PLATAFORMA
// ──────────────────────────────────────────────
model PlatformSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  value_type String   // string, number, boolean, json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("platform_settings")
}

// ──────────────────────────────────────────────
// ENUMS DE INGENIERÍA
// ──────────────────────────────────────────────
enum VariableType {
  NUMBER
  STRING
  BOOLEAN
  LIST
  FINISH_SELECTOR
  ITEM_SELECTOR
  COMPUTED
}

enum ComponentType {
  PROFILE
  GLASS
  ACCESSORY
  SUPPLY
  LABOR
}

enum RuleAction {
  INCLUDE
  EXCLUDE
  OVERRIDE_FORMULA
}

// ──────────────────────────────────────────────
// PLANTILLAS DE INGENIERÍA
// ──────────────────────────────────────────────
model EngineeringTemplate {
  id                  String    @id @default(uuid())
  tenant_id           String?
  tenant              Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  system_id           String?
  system              CatalogSystem? @relation(fields: [system_id], references: [id], onDelete: SetNull)
  name                String
  code                String
  description         String?
  image               String?   @db.Text
  is_active           Boolean   @default(true)
  source_template_id  String?
  source_template     EngineeringTemplate?  @relation("TemplateCloneOrigin", fields: [source_template_id], references: [id], onDelete: SetNull)
  cloned_templates    EngineeringTemplate[] @relation("TemplateCloneOrigin")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  pricing_method      String    @default("cost") // "cost" | "area"
  area_unit           String    @default("m2") // "m2" | "sqft"
  area_price_l1       Decimal?  @db.Decimal(10, 2)
  area_price_l2       Decimal?  @db.Decimal(10, 2)
  area_price_l3       Decimal?  @db.Decimal(10, 2)
  area_price_l4       Decimal?  @db.Decimal(10, 2)

  variables           EngineeringVariable[]
  components          EngineeringComponent[]
  quoted_products     QuotedProduct[]
  minimum_areas       TemplateMinimumArea[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([source_template_id])
  @@map("engineering_templates")
}

// ──────────────────────────────────────────────
// ÁREAS MÍNIMAS DE VENTA POR CUERPOS
// ──────────────────────────────────────────────
model TemplateMinimumArea {
  id          String              @id @default(uuid())
  template_id String
  template    EngineeringTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  bodies      Int                 // Cantidad de cuerpos (ej: 1, 2, 3...)
  min_area    Decimal             @db.Decimal(10, 2) // Área mínima facturable en la unidad de la plantilla
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt

  @@unique([template_id, bodies])
  @@map("template_minimum_areas")
}


// ──────────────────────────────────────────────
// VARIABLES DE ENTRADA DE INGENIERÍA
// ──────────────────────────────────────────────
model EngineeringVariable {
  id            String       @id @default(uuid())
  template_id   String
  template      EngineeringTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  name          String       // Nombre interno: ANCHO, ALTO, COLOR
  label         String       // Etiqueta UI: "Ancho del vano"
  type          VariableType
  default_value String?
  is_required   Boolean      @default(true)
  min_value     Decimal?     @db.Decimal(10, 2)
  max_value     Decimal?     @db.Decimal(10, 2)
  list_options  Json?        // Solo para tipo LIST: ["Opción1", "Opción2"]
  computation_formula String? // Solo para tipo COMPUTED: Fórmula para calcular la variable
  order         Int          @default(0)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@unique([template_id, name])
  @@index([template_id])
  @@map("engineering_variables")
}

// ──────────────────────────────────────────────
// COMPONENTES DEL DESGLOSE
// ──────────────────────────────────────────────
model EngineeringComponent {
  id              String        @id @default(uuid())
  template_id     String
  template        EngineeringTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  catalog_item_id String?
  catalog_item    CatalogItem?  @relation(fields: [catalog_item_id], references: [id], onDelete: SetNull)
  dynamic_item_variable String? // Nombre de la variable (ej. "VIDRIO") de la que se leerá el catalog_item_id
  type            ComponentType
  name            String        // "Jamba", "Vidrio Fijo", "Felpa"
  description     String?
  order           Int           @default(0)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  formula         EngineeringFormula?
  rules           EngineeringRule[]

  @@index([template_id])
  @@index([catalog_item_id])
  @@map("engineering_components")
}

// ──────────────────────────────────────────────
// FÓRMULAS DE CÁLCULO (DSL)
// ──────────────────────────────────────────────
model EngineeringFormula {
  id               String   @id @default(uuid())
  component_id     String   @unique
  component        EngineeringComponent @relation(fields: [component_id], references: [id], onDelete: Cascade)
  quantity_formula String   @default("1")    // Ej: "2", "NAVES * 2"
  width_formula    String?  // Ej: "ANCHO / 2 - 3.5"
  height_formula   String?  // Ej: "ALTO - HOLGURA * 2"
  length_formula   String?  // Para perfiles lineales
  area_formula     String?  // Para vidrios (m²)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("engineering_formulas")
}

// ──────────────────────────────────────────────
// REGLAS CONDICIONALES DE INGENIERÍA
// ──────────────────────────────────────────────
model EngineeringRule {
  id               String    @id @default(uuid())
  component_id     String
  component        EngineeringComponent @relation(fields: [component_id], references: [id], onDelete: Cascade)
  condition        String    // Expresión DSL: "ALTO > 1500"
  action           RuleAction
  override_formula Json?     // Fórmulas alternativas si action = OVERRIDE_FORMULA
  priority         Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([component_id])
  @@map("engineering_rules")
}

// ──────────────────────────────────────────────
// PRODUCTOS COTIZADOS
// ──────────────────────────────────────────────
model QuotedProduct {
  id                   String              @id @default(uuid())
  quote_version_id     String
  quote_version        QuoteVersion        @relation(fields: [quote_version_id], references: [id], onDelete: Cascade)
  item_type            String              @default("template") // "template" | "catalog_item" | "composite"
  
  template_id          String?
  template             EngineeringTemplate? @relation(fields: [template_id], references: [id])
  
  catalog_item_id      String?
  catalog_item         CatalogItem?         @relation(fields: [catalog_item_id], references: [id])
  
  // ── Soporte para Productos Compuestos (Fachadas) ──
  // Si is_composite=true, este ítem es un contenedor (ej. "Frente Comercial")
  // Sus sub-elementos son los hijos referenciados por parent_id
  is_composite         Boolean             @default(false)
  parent_id            String?             // FK al producto compuesto padre (null si es item raíz)
  parent               QuotedProduct?      @relation("CompositeChildren", fields: [parent_id], references: [id], onDelete: Cascade)
  components           QuotedProduct[]     @relation("CompositeChildren")
  // JSON que guarda la posición y tamaño relativo en el grid de diseño visual
  // Ej: { "x": 0, "y": 0, "w": 900, "h": 2500, "type": "product" | "divider" | "hole" }
  layout_data          Json?
  sort_order           Int                 @default(0) // Orden de visualización dentro del padre
  
  name                 String
  width                Decimal?            @db.Decimal(10, 2)  // mm (opcional para item directo)
  height               Decimal?            @db.Decimal(10, 2)  // mm (opcional)
  area                 Decimal             @default(0.0) @db.Decimal(10, 2) // m2 o sqft
  quantity             Int                 @default(1)
  unit_cost            Decimal             @default(0.0) @db.Decimal(12, 2) // Costo calculado
  unit_price           Decimal             @default(0.0) @db.Decimal(12, 2) // Costo + margen (o precio directo)
  total_price          Decimal             @default(0.0) @db.Decimal(12, 2)
  pricing_method       String              @default("cost") // "cost" | "area" | "item"
  applied_price_list   Int?                // 1, 2, 3, 4
  // Snapshot completo del resultado del motor al momento de cotizar
  engineering_snapshot Json?
  notes                String?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  @@index([quote_version_id])
  @@index([template_id])
  @@index([parent_id])
  @@map("quoted_products")
}

// ──────────────────────────────────────────────
// MÓDULO COMERCIAL: CLIENTES
// ──────────────────────────────────────────────
model Client {
  id         String    @id @default(uuid())
  tenant_id  String
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name       String
  tax_id     String?
  email      String?
  phone      String?
  address    String?
  price_list_level Int @default(1) // 1, 2, 3, 4
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  created_by String?
  updated_by String?

  contacts   Contact[]
  projects   Project[]

  @@index([tenant_id])
  @@index([is_active])
  @@map("clients")
}

// ──────────────────────────────────────────────
// CONTACTOS DE CLIENTES
// ──────────────────────────────────────────────
model Contact {
  id         String   @id @default(uuid())
  client_id  String
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  first_name String
  last_name  String?
  email      String?
  phone      String?
  position   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([client_id])
  @@map("contacts")
}

// ──────────────────────────────────────────────
// PROYECTOS
// ──────────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client_id   String
  client      Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  name        String
  description String?
  address     String?
  status      String   @default("active") // active, completed, cancelled
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  created_by  String?
  updated_by  String?

  quotes      Quote[]

  @@index([tenant_id])
  @@index([client_id])
  @@map("projects")
}

// ──────────────────────────────────────────────
// COTIZACIONES
// ──────────────────────────────────────────────
model Quote {
  id              String         @id @default(uuid())
  tenant_id       String
  tenant          Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  project_id      String
  project         Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  code            String         // e.g. "COT-2026-0001" (autogenerado)
  current_version Int            @default(1)
  status          String         @default("draft") // draft, sent, approved, rejected, cancelled
  total           Decimal        @default(0.0) @db.Decimal(12, 2)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  created_by      String?
  updated_by      String?

  versions        QuoteVersion[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([project_id])
  @@map("quotes")
}

// ──────────────────────────────────────────────
// VERSIONES DE COTIZACIONES
// ──────────────────────────────────────────────
model QuoteVersion {
  id                 String          @id @default(uuid())
  quote_id           String
  quote              Quote           @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  version_number     Int
  status             String          @default("draft") // draft, sent, approved, rejected
  subtotal           Decimal         @default(0.0) @db.Decimal(12, 2)
  discount           Decimal         @default(0.0) @db.Decimal(12, 2)
  tax                Decimal         @default(0.0) @db.Decimal(12, 2)
  total              Decimal         @default(0.0) @db.Decimal(12, 2)
  margin             Decimal?        @db.Decimal(5, 2)  // e.g. 1.40 = 40%
  payment_conditions String?
  is_current         Boolean         @default(true)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  products           QuotedProduct[]

  @@unique([quote_id, version_number])
  @@index([quote_id])
  @@map("quote_versions")
}




// ──────────────────────────────────────────────
// MÓDULO DE INVENTARIO Y COMPRAS (FASE 1)
// ──────────────────────────────────────────────

model Supplier {
  id           String     @id @default(uuid())
  tenant_id    String
  tenant       Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name         String
  tax_id       String?
  contact_name String?
  email        String?
  phone        String?
  address      String?
  is_active    Boolean    @default(true)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  purchase_orders PurchaseOrder[]

  @@index([tenant_id])
  @@map("suppliers")
}

model Warehouse {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name        String
  description String?
  is_main     Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  inventory_items  InventoryItem[]
  purchase_orders PurchaseOrder[]

  @@index([tenant_id])
  @@map("warehouses")
}

model InventoryItem {
  id              String      @id @default(uuid())
  tenant_id       String
  tenant          Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse_id    String
  warehouse       Warehouse   @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  catalog_item_id String
  catalog_item    CatalogItem @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade)
  current_stock   Decimal     @default(0.0) @db.Decimal(10, 2)
  stock_min       Decimal     @default(0.0) @db.Decimal(10, 2)
  stock_max       Decimal     @default(0.0) @db.Decimal(10, 2)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  movements       InventoryMovement[]

  @@unique([warehouse_id, catalog_item_id])
  @@index([tenant_id])
  @@index([catalog_item_id])
  @@map("inventory_items")
}

model InventoryMovement {
  id                      String   @id @default(uuid())
  tenant_id               String
  tenant                  Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inventory_item_id       String
  inventory_item          InventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)
  type                    String   // ENTRADA, SALIDA, AJUSTE, TRASLADO, PRODUCCION, DEVOLUCION_CLIENTE, DEVOLUCION_PROVEEDOR
  quantity                Decimal  @db.Decimal(10, 2) // Positivo para entradas, negativo para salidas
  date                    DateTime @default(now())
  reference_id            String?  // Ej. ID de Orden de Compra, ID de Factura, etc.
  supplier_invoice_number String?
  notes                   String?
  user_id                 String?
  user                    User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  
  receipt_id              String?
  receipt                 PurchaseOrderReceipt? @relation(fields: [receipt_id], references: [id], onDelete: SetNull)

  created_at              DateTime @default(now())

  @@index([tenant_id])
  @@index([inventory_item_id])
  @@index([receipt_id])
  @@map("inventory_movements")
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  supplier_id  String
  supplier     Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  code         String   // Ej. OC-2026-001
  warehouse_id String?
  warehouse    Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  status       String   @default("DRAFT") // DRAFT, APPROVED, SENT, PARTIAL_RECEIPT, COMPLETED, CANCELLED
  subtotal     Decimal  @default(0.0) @db.Decimal(12, 2)
  discount     Decimal  @default(0.0) @db.Decimal(12, 2)
  tax          Decimal  @default(0.0) @db.Decimal(12, 2)
  total        Decimal  @default(0.0) @db.Decimal(12, 2)
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  created_by   String?
  updated_by   String?

  items        PurchaseOrderItem[]
  receipts     PurchaseOrderReceipt[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([supplier_id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String      @id @default(uuid())
  purchase_order_id String
  purchase_order    PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  catalog_item_id   String
  catalog_item      CatalogItem @relation(fields: [catalog_item_id], references: [id], onDelete: Cascade)
  quantity          Decimal     @db.Decimal(10, 2)
  received_quantity Decimal     @default(0.0) @db.Decimal(10, 2)
  unit_price        Decimal     @default(0.0) @db.Decimal(12, 2)
  total_price       Decimal     @default(0.0) @db.Decimal(12, 2)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  @@index([purchase_order_id])
  @@index([catalog_item_id])
  @@map("purchase_order_items")
}

model PurchaseOrderReceipt {
  id                String   @id @default(uuid())
  purchase_order_id String
  purchase_order    PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  invoice_number    String?
  invoice_date      DateTime?
  notes             String?
  created_at        DateTime @default(now())
  created_by        String?
  
  movements         InventoryMovement[]

  @@index([purchase_order_id])
  @@map("purchase_order_receipts")
}

